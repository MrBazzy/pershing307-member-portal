# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
build
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# environment & secrets — never commit these
.env
.env.*
!.env.example
!.env.test

# logs
*.log
logs/

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
/typings

# System Files
.DS_Store
Thumbs.db

# local databases
*.sqlite
*.sqlite3

# PM2
.pm2/

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Server backups (nooit naar GitHub)
backups/

# Maintenance mode runtime bestanden (server-side, niet in Git)
maintenance.json
maintenance-history.log
_portal-index.bak
