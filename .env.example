# ============================================================
# Pershing No. 307 Member Portal — Environment Variables
# Copy this file to .env and fill in the values.
# In Replit, set secrets via the Secrets panel instead of a .env file.
# ============================================================

# ------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------

# PostgreSQL connection string.
# In Replit this is provided automatically. In other environments,
# format is: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/pershing307

# ------------------------------------------------------------
# Server (required)
# ------------------------------------------------------------

# TCP port the API server listens on.
# In Replit this is assigned automatically per artifact.
PORT=8080

# Node environment. Controls logging verbosity, error detail in responses,
# and whether the test-reset endpoint is active.
# Values: development | test | tda | staging | production
NODE_ENV=development

# Base URL of the deployed application (no trailing slash).
# Used to construct email links (invitation, password reset) and as the
# WebAuthn Relying Party origin.
# Example: https://pershing307.replit.app
APP_BASE_URL=https://your-domain.example.com

# Environment label shown in the portal UI banner.
# Values: TDA (Test & Acceptance) | PRD (Production) — or any short string.
APP_ENV=TDA

# ------------------------------------------------------------
# Session (required)
# ------------------------------------------------------------

# Secret used to sign session cookies. Must be long, random, and kept private.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Changing this value invalidates all existing sessions.
SESSION_SECRET=change-me-to-a-long-random-string

# Session inactivity timeout in minutes.
# After this period of no activity the session is invalidated.
# Can also be set via the admin UI (configuration table key: session_timeout_min).
# Default: 30
SESSION_TIMEOUT_MIN=30

# ------------------------------------------------------------
# Security (optional — defaults are applied if absent)
# ------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# In development, typically http://localhost:5173 or the Replit dev domain.
# In production, set to your exact domain (no trailing slash).
# Default: the value of APP_BASE_URL
ALLOWED_ORIGINS=https://your-domain.example.com

# Pino log level. Controls how much the API server logs.
# Values: fatal | error | warn | info | debug | trace | silent
# Default: info
LOG_LEVEL=info

# ------------------------------------------------------------
# Email / SMTP (required for invitations and password resets)
# ------------------------------------------------------------
# SMTP settings can also be stored in the configuration table via the admin UI.
# Environment variables take precedence over database config.
# SMTP_PASS is env-var only (never stored in the database for security).

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=portal@example.com

# SMTP password — env-var only, never stored in the database.
SMTP_PASS=your-smtp-password

# "From" email address for outgoing mail.
SMTP_FROM=portal@example.com

# Display name shown as the sender in email clients.
SMTP_FROM_NAME=Pershing 307 Portal

# ------------------------------------------------------------
# WebAuthn / Passkeys (required if passkeys_enabled = true)
# ------------------------------------------------------------
# These three values must match the domain where the portal is hosted.
# Passkey credentials are bound to the RP_ID — changing it invalidates
# all existing passkey registrations.

# The "relying party" domain (hostname only, no protocol or port).
# Example: pershing307.replit.app
WEBAUTHN_RP_ID=your-domain.example.com

# Human-readable name shown in the passkey registration prompt.
WEBAUTHN_RP_NAME=Pershing No. 307 Member Portal

# Full origin that passkey assertions will be validated against.
# Must match the browser origin exactly (protocol + host + optional port).
# Example: https://pershing307.replit.app
WEBAUTHN_RP_ORIGIN=https://your-domain.example.com

# ------------------------------------------------------------
# Object Storage (set automatically in Replit — do not edit)
# ------------------------------------------------------------
# These are injected by Replit's Object Storage integration.
# They control where uploaded documents are stored.

DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id

# Directory prefix for private (member-only) documents.
PRIVATE_OBJECT_DIR=private/

# Colon-separated list of path prefixes accessible without a signed URL.
PUBLIC_OBJECT_SEARCH_PATHS=public/
